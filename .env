# ================= Nexor Digital — configuração =================
# Copie este arquivo para .env e preencha o que for usar.

# Porta do servidor
PORT=3000

# Em produção, defina como "production" (ativa cookie seguro — exige HTTPS)
NODE_ENV=development

# Chave da sessão do painel admin. Gere uma aleatória com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Pasta onde fica o banco SQLite (padrão: ./data)
# DATA_DIR=/app/data

# ---------- Notificação por E-MAIL (opcional) ----------
# Só é ativada se TODAS as variáveis abaixo estiverem preenchidas.
# Exemplo com Gmail: SMTP_HOST=smtp.gmail.com / SMTP_PORT=587 + senha de app.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# ---------- Notificação por WEBHOOK (opcional) ----------
# Ideal para n8n ou Make: cada novo lead é enviado em JSON via POST.
# Exemplo: https://n8n.infragabrielsarria.cloud/webhook/novo-lead-nexor
WEBHOOK_URL=
